pipeline {
    agent any 

    environment {
        // 1. DRY Architecture: Core variables declared once
        AWS_REGION     = "ap-southeast-1"
        AWS_ACCOUNT_ID = "485950501937"
        
        GIT_REPO_NAME  = "AWS-EKS-DevSecOps-Project"
        GIT_EMAIL      = "abutalha3005@gmail.com"
        GIT_USER_NAME  = "LearningGallery"
        
        IMAGE_NAME     = "adservice"
        ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        REPO_URL       = "${ECR_REGISTRY}/cis-uat-adservice"
        YAML_FILE      = "adservice.yaml"
    }

    stages {
        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
                
                script {
                    // 2. Traceability: Capture the short Git SHA for the image tag
                    env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${BUILD_NUMBER}-${GIT_SHA}"
                }
            }
        }

        stage("Docker Image Build") {
            steps {
                dir('project/Project01/Apps-Code_UAT/src/adservice') {
                    // Removed the destructive system prune
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage("ECR Image Pushing") {
            steps {
                sh """
                    # 3. Dynamic Variables for AWS Login and Pushing
                    aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${REPO_URL}:${IMAGE_TAG}
                    docker push ${REPO_URL}:${IMAGE_TAG}
                """
            }
        }

        stage('Update Deployment file') {
            steps {
                dir('project/Project01/Apps-Code_UAT/kubernetes-files') {
                    withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) {
                        sh """
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"
                            
                            # Update YAML with the highly traceable tag
                            sed -i "s#image:.*#image: ${REPO_URL}:${IMAGE_TAG}#g" ${YAML_FILE}
                            
                            # 4. Explicitly add only the target file, not the whole directory
                            git add ${YAML_FILE}
                            git commit -m "Update ${IMAGE_NAME} Image to version ${IMAGE_TAG}"
                            git pull origin main --rebase
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                        """
                    }
                }
            }
        }
    }
    
    // 5. Always execute cleanup, regardless of success or failure
    post {
        always {
            cleanWs()
            // Safely remove the local Docker image to save disk space
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
        }
    }
}