pipeline {
    agent any

    environment {
        AWS_REGION     = "ap-southeast-1"
        AWS_ACCOUNT_ID = "485950501937"
        GIT_REPO_NAME  = "AWS-EKS-DevSecOps-Project"
        GIT_EMAIL      = "abutalha3005@gmail.com"
        GIT_USER_NAME  = "LearningGallery"
        ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    }

    stages {

        // 1. Add this stage at the very top!
        stage('Clean Workspace') {
            steps {
                cleanWs() 
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
                script {
                    env.GIT_SHA = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${BUILD_NUMBER}-${GIT_SHA}"
                }
            }
        }

        // --- SEQUENTIAL EXECUTION START ---
        // Jenkins will now build these exactly one at a time.
        
        stage('Build Ad Service') { steps { script { buildAndPush('adservice') } } }
        stage('Build Cart Service') { steps { script { buildAndPush('cartservice') } } }
        stage('Build Checkout Service') { steps { script { buildAndPush('checkoutservice') } } }
        stage('Build Currency Service') { steps { script { buildAndPush('currencyservice') } } }
        stage('Build Email Service') { steps { script { buildAndPush('emailservice') } } }
        stage('Build Frontend') { steps { script { buildAndPush('frontend') } } }
        stage('Build Load Generator') { steps { script { buildAndPush('loadgenerator') } } }
        stage('Build Payment Service') { steps { script { buildAndPush('paymentservice') } } }
        stage('Build Product Catalog') { steps { script { buildAndPush('productcatalogservice') } } }
        stage('Build Recommendation') { steps { script { buildAndPush('recommendationservice') } } }
        stage('Build Shipping Service') { steps { script { buildAndPush('shippingservice') } } }
        
        // --- SEQUENTIAL EXECUTION END ---

        stage('Update All YAMLs & Push to Git') {
            steps {
                dir('Project/LearningGallery/Apps-Code_UAT/kubernetes-files') {
                    withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) {
                        sh """
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"
                            
                            # Loop through all services and update their YAML files
                            for SERVICE in adservice cartservice checkoutservice currencyservice emailservice frontend loadgenerator paymentservice productcatalogservice recommendationservice shippingservice; do
                                sed -i "s#image:.*#image: ${ECR_REGISTRY}/cis-uat-\$SERVICE:${IMAGE_TAG}#g" \$SERVICE.yaml
                            done
                            
                            git add .
                            git commit -m "Deploy all services: Image tag ${IMAGE_TAG}"
                            git pull origin main --rebase
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                        """
                    }
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
    }
}

// Custom Groovy Function: This tells Jenkins exactly how to build ANY service
def buildAndPush(String serviceName) {
    dir("Project/LearningGallery/Apps-Code_UAT/src/${serviceName}") {
        script {
            // 1. Define the variable
            def dockerfilePath = "Dockerfile"
            
            // Check if this is the cartservice exception
            if (serviceName == 'cartservice') {
                dockerfilePath = "src/Dockerfile" // Tell Docker to look one folder deeper!
            }

            // 2. KEEP the sh command INSIDE this script block!
            // 3. NOTICE the -f ${dockerfilePath} added to the build command!
            sh """
                docker build -f ${dockerfilePath} -t ${serviceName}:${env.IMAGE_TAG} .
                aws ecr get-login-password --region ${env.AWS_REGION} | docker login --username AWS --password-stdin ${env.ECR_REGISTRY}
                docker tag ${serviceName}:${env.IMAGE_TAG} ${env.ECR_REGISTRY}/cis-uat-${serviceName}:${env.IMAGE_TAG}
                docker push ${env.ECR_REGISTRY}/cis-uat-${serviceName}:${env.IMAGE_TAG}
                    
                # Clean up the local Docker image immediately to save Jenkins disk space
                docker rmi ${serviceName}:${env.IMAGE_TAG} || true
            """
        } // <-- Script block closes HERE now, after the sh command finishes.
    }
}
